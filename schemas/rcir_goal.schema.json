{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eorld.example/schemas/rcir_goal.schema.json",
  "title": "RCIR Goal",
  "type": "object",
  "required": ["schema_version", "type", "goal_id", "target_predicate_refs", "status", "priority", "world_revision", "depends_on_refs"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "type": { "const": "Goal" },
    "goal_id": { "type": "string", "pattern": "^goal_[a-f0-9]{16}$" },
    "target_predicate_refs": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
    "status": { "enum": ["candidate", "active", "satisfied", "failed", "deferred", "invalidated"] },
    "priority": { "type": "integer", "minimum": 0, "maximum": 100 },
    "world_revision": { "type": "integer", "minimum": 0 },
    "depends_on_refs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "authorization_scope": { "type": "string" },
    "invalidation_reason": { "type": "string" },
    "invalidated_at_world_revision": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
