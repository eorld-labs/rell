{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/worldmodels/fact_observation_result.schema.json",
  "title": "FactObservationResult",
  "description": "双通道目标因果事实验真的运行时结果。",
  "type": "object",
  "required": ["schema_version", "fact_id", "process_instance_id", "channel_judgments", "final_establishment_state"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^1\\.\\d+\\.\\d+$" },
    "fact_id": { "type": "string" },
    "process_instance_id": { "type": "string" },
    "channel_judgments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["judgment_id", "channel_id", "channel_type", "state", "inputs"],
        "properties": {
          "judgment_id": { "type": "string" },
          "channel_id": { "type": "string" },
          "channel_type": { "type": "string", "enum": ["physical_observation", "digital_estimation"] },
          "state": { "type": "string", "enum": ["established", "not_established", "unknown"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "inputs": { "type": "object", "additionalProperties": true },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "final_establishment_state": { "$ref": "final_establishment_state.schema.json" }
  },
  "additionalProperties": false
}
