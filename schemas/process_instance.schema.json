{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/worldmodels/process_instance.schema.json",
  "title": "ProcessInstance",
  "description": "过程模板经偶然绑定数据填充后的运行实例。",
  "type": "object",
  "required": ["schema_version", "process_instance_id", "process_template_ref", "binding_ref", "task_id", "stages", "bound_parameters"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^1\\.\\d+\\.\\d+$" },
    "process_instance_id": { "type": "string" },
    "process_template_ref": { "type": "string" },
    "binding_ref": { "type": "string" },
    "task_id": { "type": "string" },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["stage_id", "required_capability", "transition_condition_ref"],
        "properties": {
          "stage_id": { "type": "string" },
          "required_capability": { "type": "string" },
          "transition_condition_ref": { "type": "string" },
          "target_fact_ref": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "bound_parameters": {
      "type": "object",
      "additionalProperties": true
    },
    "recovery_policy": {
      "type": "object",
      "properties": {
        "max_recovery_attempts": { "type": "integer", "minimum": 0 },
        "recovery_escalation": { "type": "string", "enum": ["request_human_confirmation", "stop"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
