{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eorld.example/schemas/inquiry_contract.schema.json",
  "title": "RCIR InquiryContract",
  "type": "object",
  "required": ["schema_version", "inquiry_id", "gap_type", "subject_refs", "trigger_evidence_refs", "candidate_hypotheses", "question_predicate_ref", "answer_routes", "authorization_scope", "world_revision", "depends_on_refs", "closure_condition", "status", "fact_authority_ref", "control_gateway", "verification_gateway", "direct_execution_allowed"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "inquiry_id": { "type": "string", "pattern": "^inquiry_[a-f0-9]{16}$" },
    "gap_type": { "enum": ["fact_gap", "model_drift", "process_anomaly", "concept_gap", "lifecycle_question"] },
    "subject_refs": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
    "trigger_evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
    "candidate_hypotheses": { "type": "array", "minItems": 2, "items": { "type": "string" }, "uniqueItems": true },
    "question_predicate_ref": { "type": "string" },
    "answer_routes": { "type": "array", "items": { "enum": ["existing_evidence", "passive_observation", "active_observation", "safe_probe", "human_query"] }, "uniqueItems": true },
    "expected_information_gain": { "type": "number", "minimum": 0, "maximum": 1 },
    "risk_if_ignored": { "enum": ["low", "medium", "high"] },
    "acquisition_cost": { "enum": ["low", "medium", "high"] },
    "authorization_scope": { "enum": ["read_only", "observe_only", "safe_probe", "human_query"] },
    "world_revision": { "type": "integer", "minimum": 0 },
    "depends_on_refs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "closure_condition": { "type": "string", "minLength": 1 },
    "status": { "enum": ["candidate", "admitted", "observing", "probing", "awaiting_human", "resolved", "verified", "closed", "suppressed", "deferred", "expired", "invalidated"] },
    "selected_hypothesis": { "type": ["string", "null"] },
    "resolution_evidence_refs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "arbitration_ref": { "type": ["string", "null"] },
    "verification_ref": { "type": ["string", "null"] },
    "fact_authority_ref": { "type": "string" },
    "control_gateway": { "const": "P018" },
    "verification_gateway": { "const": "P016" },
    "direct_execution_allowed": { "const": false },
    "invalidation_reason": { "type": "string" },
    "invalidated_at_world_revision": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
