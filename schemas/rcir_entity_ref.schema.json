{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eorld.example/schemas/rcir_entity_ref.schema.json",
  "title": "RCIR EntityRef",
  "type": "object",
  "required": ["schema_version", "type", "entity_ref", "concept_refs", "identity_anchors", "world_revision", "status"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "type": { "const": "EntityRef" },
    "entity_ref": { "type": "string", "minLength": 1 },
    "concept_refs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "identity_anchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["anchor_type", "anchor_value", "modality"],
        "properties": {
          "anchor_type": { "enum": ["persistent_instance_id", "spatial_track", "visual_embedding", "geometry_signature", "interaction_continuity", "external_registry"] },
          "anchor_value": { "type": "string", "minLength": 1 },
          "modality": { "enum": ["registry", "vision", "depth", "touch", "language", "runtime"] }
        },
        "additionalProperties": false
      }
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["alias_ref", "modality"],
        "properties": {
          "alias_ref": { "type": "string" },
          "modality": { "enum": ["language", "vision", "registry", "human_demonstration"] },
          "world_revision": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "world_revision": { "type": "integer", "minimum": 0 },
    "status": { "enum": ["current", "stale", "removed", "merged"] },
    "evidence_refs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
  },
  "additionalProperties": false
}
