{
  "$schema": "../process_necessity.schema.json",
  "process_id": "serve_to_human",
  "process_name": "端给人类",
  "physical_basis": "末端执行器保持水平运动——手爪维持抓取姿态，在空间中沿平滑轨迹将杯子从当前位置移动到人类面前的目标位置。全程杯中液体不应洒出（保持水平），移动不应与其他物体碰撞。",
  "stages": [
    {
      "stage_id": "stabilize",
      "stage_order": 1,
      "display_name": "稳定阶段",
      "description": "在移动之前确保手中物体姿态稳定。如果此阶段退出时杯中液体仍在晃动，表明上一过程（倒水）刚结束时或提起时引入了波动，需要等待液面平稳。",
      "qualities": [
        {
          "quality_id": "cup_tilt",
          "display_name": "杯子倾角",
          "physical_domain": "angle",
          "unit": "degree",
          "role": "observed"
        },
        {
          "quality_id": "liquid_surface_stability",
          "display_name": "液面稳定性",
          "physical_domain": "state",
          "unit": "boolean",
          "role": "observed"
        }
      ],
      "entry_conditions": [
        {
          "description": "杯子已在末端执行器内且杯内含水"
        }
      ],
      "exit_degree": {
        "degree_id": "stable_and_level",
        "display_name": "杯子水平且液面稳定",
        "condition": {
          "predicate": {
            "all": [
              {
                "quality_ref": "cup_tilt",
                "operator": "lte",
                "threshold_ref": "max_serve_tilt"
              },
              {
                "quality_ref": "liquid_surface_stability",
                "operator": "eq",
                "threshold_ref": "stable_true"
              }
            ]
          }
        },
        "target_stage": "transport"
      },
      "failure_degrees": [
        {
          "failure_id": "liquid_spilling_in_hand",
          "description": "杯子倾斜过大——可能是之前过程结束时未回正或手爪角度有误",
          "failure_type": "unexpected_state",
          "recovery_hint": "立即降低移动速度；调整手爪角度使杯子恢复水平"
        }
      ]
    },
    {
      "stage_id": "transport",
      "stage_order": 2,
      "display_name": "搬运阶段",
      "description": "沿规划路径将杯子移动到目标位置。全程保持杯子水平且加速度不超过洒出阈值。此阶段的核心矛盾是速度（效率）与加速度（不洒）之间的物理权衡。",
      "qualities": [
        {
          "quality_id": "cup_tilt",
          "display_name": "杯子倾角",
          "physical_domain": "angle",
          "unit": "degree",
          "role": "observed"
        },
        {
          "quality_id": "distance_to_target",
          "display_name": "到目标位置的距离",
          "physical_domain": "distance",
          "unit": "cm",
          "role": "observed"
        },
        {
          "quality_id": "collision_risk",
          "display_name": "碰撞风险",
          "physical_domain": "state",
          "unit": "boolean",
          "role": "observed"
        }
      ],
      "entry_conditions": [
        {
          "description": "稳定阶段退出（杯子水平且液面稳定）"
        }
      ],
      "exit_degree": {
        "degree_id": "arrived_at_target",
        "display_name": "到达目标位置",
        "condition": {
          "predicate": {
            "all": [
              {
                "quality_ref": "distance_to_target",
                "operator": "lte",
                "threshold_ref": "arrival_threshold"
              },
              {
                "quality_ref": "cup_tilt",
                "operator": "lte",
                "threshold_ref": "max_serve_tilt"
              }
            ]
          }
        },
        "target_stage": "present"
      },
      "failure_degrees": [
        {
          "failure_id": "collision_imminent",
          "description": "前方检测到障碍物——移动路径被阻挡",
          "failure_type": "mechanism_blocked",
          "recovery_hint": "暂停移动；检查障碍物是否可自主移开；若不能，请求人类移开障碍物或选择替代路径"
        },
        {
          "failure_id": "spill_during_transport",
          "description": "移动过程中杯子倾角超出安全范围——加速过猛或急停",
          "failure_type": "boundary_exceeded",
          "recovery_hint": "立即减速至静止；等待液面恢复平稳后重新搬运"
        }
      ]
    },
    {
      "stage_id": "present",
      "stage_order": 3,
      "display_name": "呈现阶段",
      "description": "到达目标位置后，将杯子稳定地放在人类面前的放置面上，并释放夹爪。释放前必须确认杯子已完全接触放置面——在半空释放会导致杯子坠落。",
      "qualities": [
        {
          "quality_id": "cup_contact_with_surface",
          "display_name": "杯子与放置面的接触状态",
          "physical_domain": "contact",
          "unit": "boolean",
          "role": "observed"
        },
        {
          "quality_id": "cup_stability",
          "display_name": "杯子在放置面上的稳定性",
          "physical_domain": "state",
          "unit": "boolean",
          "role": "observed"
        }
      ],
      "entry_conditions": [
        {
          "description": "搬运阶段退出（到达目标位置且杯子水平）"
        }
      ],
      "exit_degree": {
        "degree_id": "cup_placed_and_released",
        "display_name": "杯子已放置在桌面上且手爪已释放",
        "condition": {
          "predicate": {
            "all": [
              {
                "quality_ref": "cup_contact_with_surface",
                "operator": "eq",
                "threshold_ref": "contact_true"
              },
              {
                "quality_ref": "cup_stability",
                "operator": "eq",
                "threshold_ref": "stable_true"
              }
            ]
          }
        },
        "target_stage": "__terminal__"
      },
      "failure_degrees": [
        {
          "failure_id": "premature_release",
          "description": "杯子未完全接触放置面就被释放——杯子可能倾倒或坠落",
          "failure_type": "boundary_exceeded",
          "recovery_hint": "在释放前必须同时确认 contact_state 为真；若已释放且杯子倾斜，立即尝试重新抓取"
        },
        {
          "failure_id": "unstable_placement",
          "description": "杯子放在放置面上后晃动或倾斜——放置面不平或杯子底部不规则",
          "failure_type": "unexpected_state",
          "recovery_hint": "等待1秒确认稳定性；若杯子仍未稳定，重新抓取并选择另一个放置位置"
        }
      ]
    }
  ]
}
