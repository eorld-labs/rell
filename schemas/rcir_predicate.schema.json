{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eorld.example/schemas/rcir_predicate.schema.json",
  "title": "RCIR Predicate",
  "type": "object",
  "required": ["schema_version", "type", "predicate_id", "name", "arguments", "polarity", "modality", "status", "world_revision", "evidence_refs"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "type": { "const": "Predicate" },
    "predicate_id": { "type": "string", "pattern": "^predicate_[a-f0-9]{16}$" },
    "name": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]*$" },
    "arguments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "value_type", "value"],
        "properties": {
          "role": { "type": "string" },
          "value_type": { "enum": ["EntityRef", "Concept", "literal", "role_variable"] },
          "value": {}
        },
        "additionalProperties": false
      }
    },
    "polarity": { "enum": ["positive", "negative"] },
    "modality": { "enum": ["current_fact", "goal_candidate", "reported_candidate", "perception_candidate", "hypothesis", "template_boundary"] },
    "status": { "enum": ["candidate", "established", "refuted", "stale", "invalidated"] },
    "world_revision": { "type": "integer", "minimum": 0 },
    "evidence_refs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "depends_on_refs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "provenance": {
      "type": "object",
      "required": ["inference_kind", "premise_refs", "temporal_window"],
      "properties": {
        "inference_kind": { "enum": ["explicit_spatial_marker", "current_verified_relation", "verified_event_relation", "defaulted_from_affordance"] },
        "inference_rule": { "type": "string" },
        "premise_refs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "strength": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "temporal_window": {
          "type": "object",
          "required": ["interaction_turn", "temporal_scope", "valid_from_world_revision", "expires_on_world_revision_change"],
          "properties": {
            "interaction_turn": { "type": "integer", "minimum": 0 },
            "temporal_scope": { "enum": ["reported_past", "current", "requested_future", "requested_current_or_future", "verified_transition"] },
            "valid_from_world_revision": { "type": "integer", "minimum": 0 },
            "valid_until_world_revision": { "type": ["integer", "null"], "minimum": 0 },
            "temporal_anchor_ref": { "type": ["string", "null"] },
            "dialogue_distance": { "type": "integer", "minimum": 0 },
            "expires_on_world_revision_change": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "invalidation_reason": { "type": "string" },
    "invalidated_at_world_revision": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
