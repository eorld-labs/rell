{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/worldmodels/schemas/rell_machine_dictionary.schema.json",
  "title": "RELL Executable Machine Dictionary",
  "type": "object",
  "required": ["schema_version", "dictionary_id", "architecture", "entries"],
  "properties": {
    "schema_version": {"const": "1.1.0"},
    "dictionary_id": {"type": "string", "minLength": 1},
    "architecture": {
      "type": "object",
      "required": ["glyph", "word", "sentence", "discourse"],
      "additionalProperties": {"type": "string"}
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["entry_id", "entry_kind", "semantic_value", "irreducible", "components", "roles", "language_adapters", "fact_commit_authority"],
        "properties": {
          "entry_id": {"type": "string", "pattern": "^[a-z_]+\\.[a-z0-9_]+$"},
          "entry_kind": {"enum": ["primitive_predicate", "primitive_operator", "modifier", "operator_contract", "process_template", "domain_pack_entry", "speech_act", "query_contract", "communicative_contract"]},
          "semantic_value": {"type": "string", "minLength": 1},
          "irreducible": {"type": "boolean"},
          "components": {"type": "array", "items": {"type": "string"}},
          "roles": {"type": "object"},
          "modifier_dimension": {"type": "string", "minLength": 1},
          "modifier_value": {"type": "string", "minLength": 1},
          "default_scope": {"enum": ["event", "global"]},
          "language_adapters": {"type": "object"},
          "verification_contract": {"type": "array", "items": {"type": "string"}},
          "causal_contract": {
            "type": "object",
            "required": ["requires", "projects", "verification"],
            "properties": {
              "requires": {"type": "array", "items": {"type": "string"}},
              "projects": {"type": "array", "items": {"type": "string"}},
              "verification": {"type": "array", "items": {"type": "string"}}
            },
            "additionalProperties": false
          },
          "communication_contract": {
            "type": "object",
            "required": ["requires_context", "projects_dialogue_state", "verification"],
            "properties": {
              "requires_context": {"type": "array", "items": {"type": "string"}},
              "projects_dialogue_state": {"type": "array", "items": {"type": "string"}},
              "verification": {"type": "array", "items": {"type": "string"}},
              "read_authority": {"type": "array", "items": {"type": "string"}}
            },
            "additionalProperties": false
          },
          "fact_commit_authority": {"enum": ["none", "P016_via_WorldFactLedger_only"]}
        },
        "allOf": [
          {
            "if": {"properties": {"entry_kind": {"const": "modifier"}}},
            "then": {"required": ["modifier_dimension", "modifier_value", "default_scope"]}
          },
          {
            "if": {"properties": {"entry_kind": {"enum": ["speech_act", "query_contract", "communicative_contract"]}}},
            "then": {"required": ["communication_contract"]}
          }
        ],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
