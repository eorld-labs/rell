{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/worldmodels/schemas/machine_dictionary_equivalence_receipt.schema.json",
  "title": "Machine Dictionary Shadow Equivalence Receipt",
  "type": "object",
  "required": [
    "schema_version",
    "receipt_kind",
    "receipt_id",
    "mode",
    "world_revision",
    "field_results",
    "status",
    "divergent_fields",
    "promotion_blockers",
    "eligible_for_authority_promotion",
    "can_control_execution",
    "can_commit_runtime_fact",
    "surface_text_reparsed",
    "runtime_fact_committed"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "receipt_kind": {"const": "MachineDictionaryEquivalenceReceipt"},
    "receipt_id": {"type": "string", "pattern": "^dictionary_equivalence_[a-f0-9]{16}$"},
    "mode": {"const": "shadow_equivalence_migration"},
    "world_revision": {"type": "integer", "minimum": 0},
    "projection_lattice_ref": {"type": ["string", "null"]},
    "field_results": {
      "type": "object",
      "required": ["speech_act_and_query", "operators", "roles", "modifiers_and_scope", "goal_relation", "unresolved_variables", "references", "discourse_edges", "recovery_context", "event_frames"],
      "additionalProperties": {
        "type": "object",
        "required": ["status", "expected", "actual", "blocks_authority_promotion"],
        "properties": {
          "status": {"enum": ["equivalent", "divergent"]},
          "expected": {},
          "actual": {},
          "blocks_authority_promotion": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "status": {"enum": ["equivalent", "divergent"]},
    "divergent_fields": {"type": "array", "items": {"type": "string"}},
    "promotion_blockers": {"type": "array", "items": {"type": "string"}},
    "eligible_for_authority_promotion": {"type": "boolean"},
    "can_control_execution": {"const": false},
    "can_commit_runtime_fact": {"const": false},
    "surface_text_reparsed": {"const": false},
    "runtime_fact_committed": {"const": false}
  },
  "additionalProperties": false
}
