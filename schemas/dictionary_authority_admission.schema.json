{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/worldmodels/schemas/dictionary_authority_admission.schema.json",
  "title": "RELL Dictionary Semantic Authority Admission",
  "type": "object",
  "required": [
    "schema_version",
    "admission_kind",
    "admission_id",
    "mode",
    "admission_status",
    "authoritative_semantic_source",
    "fallback_used",
    "fallback_reasons",
    "world_revision",
    "revision_dependencies",
    "semantic_input",
    "legacy_parser_role",
    "downstream_legacy_semantic_fields_allowed",
    "downstream_surface_reparse_allowed",
    "can_generate_situated_event_graph",
    "can_control_execution",
    "can_commit_runtime_fact",
    "runtime_fact_committed"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "admission_kind": {"const": "DictionaryAuthorityAdmission"},
    "admission_id": {"type": "string", "pattern": "^dictionary_admission_[a-f0-9]{16}$"},
    "mode": {"const": "controlled_authority_trial"},
    "admission_status": {"enum": ["admitted", "fallback"]},
    "authoritative_semantic_source": {"enum": ["machine_dictionary", "legacy_structured_compatibility_adapter"]},
    "fallback_used": {"type": "boolean"},
    "fallback_reasons": {"type": "array", "items": {"type": "string"}},
    "dictionary_ref": {"type": ["string", "null"]},
    "projection_ref": {"type": ["string", "null"]},
    "projection_digest": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "lattice_ref": {"type": ["string", "null"]},
    "equivalence_receipt_ref": {"type": ["string", "null"]},
    "world_revision": {"type": "integer", "minimum": 0},
    "revision_dependencies": {
      "type": "object",
      "required": ["projection", "lattice", "receipt"],
      "additionalProperties": {"type": ["integer", "null"]}
    },
    "semantic_input": {"type": "object"},
    "legacy_parser_role": {"enum": ["upstream_dictionary_projection_adapter", "monitored_structured_compatibility_adapter"]},
    "downstream_legacy_semantic_fields_allowed": {"const": false},
    "downstream_surface_reparse_allowed": {"const": false},
    "recovery_reentered_current_fact_pruning": {"type": "boolean"},
    "can_generate_situated_event_graph": {"const": true},
    "can_control_execution": {"const": false},
    "can_commit_runtime_fact": {"const": false},
    "runtime_fact_committed": {"const": false}
  },
  "additionalProperties": false
}
